# Ready Concierge — Environment Variables
# Copy this file to .env and fill in your credentials.

# === Required ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=concierge@aviara.preshift.app
DEFAULT_STAFF_EMAIL=concierge@parkhyattaviara.com

# === Recommended ===
DEFAULT_SIGNAL_RECIPIENTS=concierge@parkhyattaviara.com,gm@parkhyattaviara.com
DEFAULT_COMPANY_NAME=Park Hyatt
DEFAULT_PROPERTY_NAME=Park Hyatt Aviara
DEFAULT_STREAM_NAME=Concierge

# === Optional (have sensible defaults) ===
# DATABASE_URL=sqlite:///./ready_concierge.db
